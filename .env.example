# ─── Server ───────────────────────────────────────────
# Internal container port (leave as 3000 for Docker)
PORT=3000
NODE_ENV=development

# External host port mapped by docker-compose (change if 3000 is taken)
GATE_CONCIERGE_PORT=3000

# ─── Database ─────────────────────────────────────────
# SQLite file path (inside container)
DATABASE_PATH=/app/data/gate-concierge.db
# Directory used for the SQLite DB AND the WhatsApp auth state
DATA_DIR=/app/data

# ─── Admin Dashboard Credentials ──────────────────────
# HTTP Basic auth for /admin and /api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# ─── Visitor Pass Defaults (hours) ────────────────────
DEFAULT_VALIDITY_BEFORE_HOURS=2
DEFAULT_VALIDITY_AFTER_HOURS=4

# ─── WhatsApp (Baileys — WhatsApp Web multi-device) ───
# The bot pairs with your personal WhatsApp number by scanning a QR code.
# On first run, check container logs (or open /admin → WhatsApp panel) to
# see the QR, then scan from your phone:
#   WhatsApp → Settings → Linked Devices → Link a Device
#
# Pairing state is persisted under ${DATA_DIR}/wa-auth so you only pair once.

# Enable / disable the WhatsApp socket (default: true)
WA_ENABLED=true

# Where pairing state is stored (defaults to ${DATA_DIR}/wa-auth)
WA_AUTH_DIR=/app/data/wa-auth

# Wake word for group chats (case-insensitive). Messages starting with this
# word — or with a leading "/" — are treated as commands. Everything else
# in a group is ignored. In DMs, every message is treated as a command.
WA_GROUP_TRIGGER=luna

# Mark incoming messages as read after processing (default: true)
WA_MARK_READ=true

# Print the pairing QR code to container logs as ASCII (default: true)
WA_PRINT_QR=true

# ─── Legacy OpenClaw (deprecated; leave unset) ────────
# Only set these if you still need the old HTTP bridge for some reason.
# OPENCLAW_WEBHOOK_SECRET=
# OPENCLAW_API_URL=
# OPENCLAW_API_KEY=
# OPENCLAW_PHONE_NUMBER_ID=
